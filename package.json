{
  "name": "infra-pipeline",
  "version": "1.0.0",
  "description": "AWS CDK deployment pipeline for Terraform-based landing zone deployment",
  "main": "bin/pipeline-stack.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
