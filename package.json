    "checkov": "cdk synth && checkov --config-file .checkov.yaml"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "^2.176.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@aws-sdk/client-codepipeline": "^3.1079.0",
    "@aws-sdk/client-dynamodb": "^3.1079.0",
